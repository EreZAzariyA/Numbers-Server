# ============================================================================
# Numbers-Server — environment variable reference
# ============================================================================
# Canonical list of every variable the backend reads. Committed to git, so it
# MUST contain placeholders only — never real secrets.
#
# The app loads a single `.env` file (require('dotenv').config()). To run the
# server, copy the template for your environment to `.env`:
#   Local dev :  cp .env.development .env
#   IIS / prod:  cp .env.production  .env   # then fill in real values
#
# docker-compose.yml (in this directory) also reads this `.env` for ${VAR}
# substitution when running `docker compose up` from Numbers-Server.
#
# Which config block applies is chosen by NODE_ENV (src/utils/config.ts):
#   unset / != "production"  -> DevelopmentConfig (SECRET_KEY/CORS hardcoded; Mongo+Redis read from env)
#   "production"             -> ProductionConfig  (all vars read from env)
# ----------------------------------------------------------------------------

# --- Runtime --------------------------------------------------------------
NODE_ENV=development          # development | production
PORT=5000

# --- Datastores -----------------------------------------------------------
# REQUIRED in all environments — no hardcoded fallbacks.
MONGO_CONNECTION_STRING=mongodb://127.0.0.1:27017/numbers
REDIS_URL=redis://127.0.0.1:6379

# --- Security -------------------------------------------------------------
# JWT signing key. Dev: hardcoded as "secret" in DevelopmentConfig. Prod: REQUIRED.
SECRET_KEY=change-me
# Encrypts stored bank credentials. MUST stay identical across deploys, or
# previously-encrypted credentials become undecryptable.
BANK_CREDENTIALS_ENCRYPTION_SECRET=change-me
# Optional: encrypts stored AI provider keys. Falls back to SECRET_KEY if unset.
AI_SETTINGS_ENCRYPTION_SECRET=

# --- Google OAuth ---------------------------------------------------------
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# --- AI providers ---------------------------------------------------------
# Gemini/Claude API keys are configured per user inside the app (stored
# encrypted in the DB), not via server env. Model IDs are pinned in code
# (src/bll/ai-settings.ts — DEFAULT_GEMINI_MODEL / DEFAULT_CLAUDE_MODEL).
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:4b
# Dedicated embedding model for agent memory. Must support /api/embed and return 768-dim vectors.
# Recommended: nomic-embed-text  (run: ollama pull nomic-embed-text)
# Leave empty to disable Ollama-backed memory (Gemini memory still works without this).
OLLAMA_EMBEDDING_MODEL=

# --- Bank scraping (Puppeteer) -------------------------------------------
# Path to a system Chrome/Chromium binary. On Windows/IIS, point at installed Chrome.
PUPPETEER_EXECUTABLE_PATH=
ENABLE_PATTERN_PERSISTENCE=true

# --- Background workers ---------------------------------------------------
ENABLE_NIGHTLY_REFRESH=false
NIGHTLY_REFRESH_CRON=0 2 * * *
SCRAPING_WORKER_CONCURRENCY=1
TRANSACTION_IMPORT_WORKER_CONCURRENCY=1
PATTERN_RECOMPUTE_WORKER_CONCURRENCY=1
PATTERN_RECOMPUTE_DEBOUNCE_MS=5000

# --- Bank scraper tuning (optional) ---------------------------------------
BANK_SCRAPER_LOOKBACK_MONTHS=12
BANK_SCRAPER_TIMEOUT_MS=60000
BANK_SCRAPER_HEADLESS=true

# --- Rate limiting (optional; defaults in config.ts) ----------------------
RATE_LIMIT_GLOBAL_WINDOW_MS=60000
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_BANK_WINDOW_MS=3600000
RATE_LIMIT_BANK_MAX=10

# --- Queue retention (optional) ------------------------------------------
QUEUE_REMOVE_ON_COMPLETE_AGE_SECONDS=3600
QUEUE_REMOVE_ON_FAIL_AGE_SECONDS=86400
NIGHTLY_QUEUE_REMOVE_ON_COMPLETE_AGE_SECONDS=86400
NIGHTLY_QUEUE_REMOVE_ON_FAIL_AGE_SECONDS=604800
