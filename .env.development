# Local development template — copy to `.env`:  cp .env.development .env
#
# Both MONGO_CONNECTION_STRING and REDIS_URL are required even in dev.
# SECRET_KEY is hardcoded as "secret" in DevelopmentConfig so it can be omitted here.

PORT=5000

# Datastores (required — no hardcoded fallbacks)
MONGO_CONNECTION_STRING=mongodb://127.0.0.1:27017/numbers
REDIS_URL=redis://192.168.1.173:6379

# Security
BANK_CREDENTIALS_ENCRYPTION_SECRET=change-me
AI_SETTINGS_ENCRYPTION_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# AI providers
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:4b
OLLAMA_EMBEDDING_MODEL=

# Bank scraping
PUPPETEER_EXECUTABLE_PATH=
ENABLE_PATTERN_PERSISTENCE=true
