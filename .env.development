# Local development template — copy to `.env`:  cp .env.development .env
#
# NODE_ENV is intentionally left unset so src/utils/config.ts uses
# DevelopmentConfig, where Mongo, SECRET_KEY and CORS origins are hardcoded
# for local dev. Fill the secret placeholders with your own dev values; do
# not commit real values (the active `.env` copy is gitignored).

PORT=5000
REDIS_URL=redis://localhost:6379

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Bank credential encryption (Gemini/Claude keys are set per user in-app)
BANK_CREDENTIALS_ENCRYPTION_SECRET=change-me

# Local model / pattern persistence
ENABLE_PATTERN_PERSISTENCE=true
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:4b
