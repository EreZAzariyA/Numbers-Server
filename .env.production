# Production template for the IIS server — copy to `.env`:  cp .env.production .env
#
# Replace every placeholder with a real value. The active `.env` copy holds
# real secrets and MUST stay out of git (it is gitignored).
# NODE_ENV=production can also be set by the Windows service (e.g. NSSM
# AppEnvironmentExtra); setting it here as well is fine.

NODE_ENV=production
PORT=5000

# Datastores (required in production)
MONGO_CONNECTION_STRING=mongodb://127.0.0.1:27017/numbers
REDIS_URL=redis://localhost:6379

# Security (required in production)
SECRET_KEY=replace-with-a-long-random-string
# MUST match the secret used when bank credentials were first encrypted,
# or stored credentials can no longer be decrypted.
BANK_CREDENTIALS_ENCRYPTION_SECRET=replace-with-existing-secret

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# AI providers (Gemini/Claude API keys are set per user in-app, not here)
GEMINI_MODEL=gemini-2.5-flash

# Bank scraping — point Puppeteer at the Windows Chrome install
PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
ENABLE_PATTERN_PERSISTENCE=true

# Background workers (production runs them; requires Redis)
ENABLE_NIGHTLY_REFRESH=true
NIGHTLY_REFRESH_CRON=0 2 * * *
SCRAPING_WORKER_CONCURRENCY=2
TRANSACTION_IMPORT_WORKER_CONCURRENCY=3
PATTERN_RECOMPUTE_WORKER_CONCURRENCY=2
